# EditorConfig — https://editorconfig.org
# Ramboll Developer Platform monolith defaults (multi-language).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{js,jsx,ts,tsx,vue,css,scss,html}]
indent_size = 2

[*.{yml,yaml,json,toml,tf,tfvars}]
indent_size = 2

[*.go]
indent_style = tab

[*.cs]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
