[build-system]
requires = ["setuptools>=68", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">=3.11"
license = { text = "LicenseRef-Ramboll-Internal" }
authors = [{ name = "{{ author }}" }]
keywords = ["{{ department.team_slug }}", "ramboll", "api", "service"]
dependencies = []

[project.optional-dependencies]
# HTTP surface. Install with: pip install -e ".[api]"
api = [
  "fastapi>=0.110",
  "uvicorn[standard]>=0.27",
]
# Local development + CI toolchain. Includes the api extra so `pip install
# ".[dev]"` (what the reusable CI workflows run) can lint/type-check api.py.
dev = [
  "{{ project_name }}[api]",
  "pytest>=8.0",
  "hypothesis>=6.100",
  "ruff>=0.4",
  "black>=24.3",
  "mypy>=1.9",
]

[tool.setuptools.packages.find]
where = ["src"]

[tool.ruff]
line-length = 100
target-version = "py311"
src = ["src", "tests"]

[tool.ruff.lint]
# A pragmatic-but-strict default set: pyflakes, pycodestyle, isort, bugbear,
# comprehensions, pyupgrade, simplify, naming.
select = ["E", "F", "I", "B", "C4", "UP", "SIM", "N", "W"]

[tool.ruff.lint.per-file-ignores]
# Tests may use assert and slightly looser conventions.
"tests/**" = ["S101"]

[tool.black]
line-length = 100
target-version = ["py311"]

[tool.mypy]
python_version = "3.11"
files = ["src", "tests"]
strict = true
warn_unused_configs = true
warn_redundant_casts = true
warn_unused_ignores = true
disallow_untyped_defs = true
no_implicit_optional = true
show_error_codes = true

[[tool.mypy.overrides]]
# Hypothesis ships types but keep tests unblocked if a strategy lacks them.
module = "hypothesis.*"
ignore_missing_imports = true

[tool.pytest.ini_options]
minversion = "8.0"
testpaths = ["tests"]
addopts = "-ra"
