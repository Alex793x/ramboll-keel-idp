/**
 * HTTP entry point for {{ project_name }} — {{ description }}
 *
 * Plain `node:http` — zero runtime dependencies by design. The routing logic
 * is pure and lives in `routes.ts`; this file is only the impure wiring
 * (sockets, serialization, logging).
 *
 * Generated by Keel (Ramboll Developer Platform) from the `api-node` service
 * blueprint. Owned by the {{ department.name }} department.
 */
import { createServer, type IncomingMessage, type ServerResponse } from "node:http";
import { resolveRoute, type Route } from "./routes.js";

export const SERVICE_NAME = "{{ project_name }}";
export const SERVICE_VERSION = "0.1.0";

/** The service's route table. Add routes here; keep handlers pure. */
export const routes: readonly Route[] = [
  {
    method: "GET",
    path: "/health",
    handle: () => ({
      status: 200,
      body: { status: "ok", service: SERVICE_NAME, version: SERVICE_VERSION },
    }),
  },
];

/** Bridge one incoming request through the pure resolver onto the response. */
export function handleRequest(req: IncomingMessage, res: ServerResponse): void {
  const resolution = resolveRoute(routes, req.method ?? "GET", req.url ?? "/");

  if (resolution.kind === "ok") {
    writeJson(res, resolution.response.status, resolution.response.body);
    return;
  }
  if (resolution.kind === "method_not_allowed") {
    res.setHeader("allow", resolution.allowed.join(", "));
    writeJson(res, 405, { error: "method not allowed" });
    return;
  }
  writeJson(res, 404, { error: "not found" });
}

function writeJson(res: ServerResponse, status: number, body: Record<string, unknown>): void {
  const payload = JSON.stringify(body);
  res.writeHead(status, { "content-type": "application/json; charset=utf-8" });
  res.end(payload);
}

const port = Number(process.env.PORT ?? 8000);

// Only listen when executed directly (`node dist/server.js`) so tests can
// import the route table without opening sockets.
if (process.argv[1]?.endsWith("server.js")) {
  createServer(handleRequest).listen(port, () => {
    console.log(`${SERVICE_NAME} listening on :${port}`);
  });
}
