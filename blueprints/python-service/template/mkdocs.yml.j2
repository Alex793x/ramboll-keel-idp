site_name: {{ project_name }}
site_description: {{ description }}
site_author: {{ owning_team }}

theme:
  name: material
  palette:
    - scheme: default
      primary: blue
      accent: cyan
  features:
    - navigation.sections
    - navigation.top
    - content.code.copy
    - toc.integrate

nav:
  - Home: index.md
  - Getting started: getting-started.md
  - Architecture: architecture.md
  - Runbook: runbook.md
  - Contributing: contributing.md
  - Decisions:
      - "ADR-0001 — Record architecture decisions": adr/0001-record-architecture-decisions.md

markdown_extensions:
  - admonition
  - toc:
      permalink: true
  - pymdownx.highlight
  - pymdownx.superfences

# `mkdocs build --strict` runs in CI (Validate); broken links/nav fail the build.
