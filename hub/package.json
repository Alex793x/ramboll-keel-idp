{
  "name": "keel-hub",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Keel hub — the self-service project-initialization UI for the Ramboll Developer Platform (TanStack Start).",
  "scripts": {
    "dev": "vite dev --port 3000",
